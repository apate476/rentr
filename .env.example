# ============================================================
# RENTR — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ============================================================

# ------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# Get these from: Project Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# WARNING: Service role key has full DB access — server-side ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Google Places API (address autocomplete + geocoding)
# Create at: https://console.cloud.google.com
# Enable: Maps JavaScript API, Places API, Geocoding API
# Restrict key by HTTP referrer to your domain
# ------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# ------------------------------------------------------------
# Mapbox (interactive map)
# Create at: https://account.mapbox.com/access-tokens
# Restrict token to your domain
# Scopes needed: styles:read, tiles:read
# ------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=

# ------------------------------------------------------------
# Cloudflare Turnstile (CAPTCHA on review form)
# Create at: https://dash.cloudflare.com → Turnstile
# ------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Server-side only — never use NEXT_PUBLIC_ prefix here
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------
# Upstash Redis (rate limiting)
# Create at: https://console.upstash.com
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# V2 — Add when ready (do not add NEXT_PUBLIC_ prefix to secrets)
# ------------------------------------------------------------
# ANTHROPIC_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
